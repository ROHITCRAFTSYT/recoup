# Copy to .env and fill in.
# PostgreSQL (Neon recommended for Vercel). DATABASE_URL is the pooled URL used at
# runtime; DIRECT_URL is the direct (non-pooled) URL used for migrations. On
# Vercel, creating a Postgres store in the Storage tab injects these automatically.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# Required — signs the session cookie (any long random string).
AUTH_SECRET=""

# AI provider — pick ONE (agents fall back to deterministic heuristics if none).
# Groq is free + fast: https://console.groq.com/keys
GROQ_API_KEY=""
# Or Claude (paid): https://console.anthropic.com
ANTHROPIC_API_KEY=""
# Other OpenAI-compatible providers also work: OPENAI_API_KEY / GEMINI_API_KEY /
# OPENROUTER_API_KEY, or a fully custom AI_BASE_URL + AI_API_KEY + AI_MODEL.
# Force a provider with AI_PROVIDER=groq|anthropic|openai|gemini|openrouter|ollama.

# Optional — enables Voyage semantic search over the collections playbook.
# Leave empty to use the built-in keyword-search fallback.
VOYAGE_API_KEY=""

# Optional — Telegram integration (authorization alerts + approve-from-phone +
# two-way debtor replies). Create a bot via @BotFather, DM it, then read your
# chat id from https://api.telegram.org/bot<TOKEN>/getUpdates.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_MANAGER_CHAT_ID=""
# Only needed if you set a public webhook (production); secures POST /api/telegram.
TELEGRAM_WEBHOOK_SECRET=""

# Optional — base URL used in Telegram "Open case" links (e.g. your tunnel/host).
APP_URL="http://localhost:3000"

# Optional — Lemma pod integration (live datastore + approval gate mirroring).
# Get these from https://lemma.work after creating a pod.
LEMMA_API_URL="https://api.lemma.work"
LEMMA_POD_ID=""
LEMMA_TOKEN=""
# Optional — browser SDK showcase (SDK Explorer → "Browser SDK" tab). Runs the
# OFFICIAL lemma-sdk npm package directly in the browser, so the token is
# client-visible: use a SHORT-LIVED pod token, not a long-lived service token.
# Leave blank to keep everything on the secure server-side proxy (the default).
NEXT_PUBLIC_LEMMA_POD_ID=""
NEXT_PUBLIC_LEMMA_TOKEN=""
NEXT_PUBLIC_LEMMA_API_URL="https://api.lemma.work"
