# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# database (SQLite) — recreated via `npm run db:reset && npm run db:seed`
*.db
*.db-journal
prisma/*.db

# generated prisma client — recreated via `prisma generate` (postinstall)
/src/generated

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
